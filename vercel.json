{
  "services": {
    "web": {
      "root": "apps/web",
      "framework": "nextjs"
    },
    "scheduler": {
      "root": "services/scheduler"
    }
  },
  "rewrites": [
    {
      "source": "/api/scheduler(/.*)?",
      "destination": {
        "type": "service",
        "service": "scheduler"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "web"
      }
    }
  ]
}
