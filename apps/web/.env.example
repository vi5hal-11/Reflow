# Supabase (client-safe; RLS is the security boundary)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Public URL of this app (used in auth redirect links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Internal URL of the FastAPI scheduler service (server-side only)
SCHEDULER_URL=http://localhost:8000

# Supabase secret key (sb_secret_...). NOT needed to run the app — the web app
# talks to Supabase only through RLS-scoped user sessions. It is used solely by
# the signed-in Playwright suite to seed a test user; without it those specs
# skip themselves. Never expose it to the browser.
SUPABASE_SECRET_KEY=

# Google sign-in ("Continue with Google") needs no env here — its client ID and
# secret live in the Supabase dashboard (Authentication → Providers → Google).
