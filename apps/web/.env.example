# Supabase (client-safe; RLS is the security boundary)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Public URL of this app (used in auth redirect links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Internal URL of the FastAPI scheduler service (server-side only)
SCHEDULER_URL=http://localhost:8000

# Google Calendar sync (Phase 4; all server-side only — never NEXT_PUBLIC).
# OAuth client from Google Cloud Console; redirect URI must be
# {NEXT_PUBLIC_SITE_URL}/api/calendar/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Supabase secret key (sb_secret_...) — required to store/read OAuth tokens
# in calendar_connections, which has no RLS policies by design.
SUPABASE_SECRET_KEY=
